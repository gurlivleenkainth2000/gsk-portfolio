# ---------------------------------------------------------------------------
# Contact form (app/api/contact/route.ts) — Resend
# Copy to .env.local for local dev (.env*.local is gitignored).
# In production, store RESEND_API_KEY in Cloud Secret Manager:
#   firebase apphosting:secrets:set gsk-portfolio-resend-api-key
# and reference it from apphosting.yaml; the CONTACT_* vars are plain values.
# ---------------------------------------------------------------------------

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender on your Resend domain. Must be on a domain you verified in
# Resend (gurlivleen.dev), NOT a free gmail/outlook address.
CONTACT_FROM_EMAIL="Portfolio Contact <contact@gurlivleen.dev>"

# Where contact messages are delivered. Using the domain alias (forwarded to
# Gmail via Cloudflare Email Routing) keeps the personal inbox out of the repo.
CONTACT_TO_EMAIL=contact@gurlivleen.dev
